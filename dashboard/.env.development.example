# Dashboard — development env example
# Copy this file to .env.development and fill in the real values.

# Base URL of the running backend.
# When running locally:  http://localhost:8080/api
# When backend is tunneled through ngrok, replace with the ngrok HTTPS URL:
#   VITE_API_BASE_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app/api
VITE_API_BASE_URL=http://localhost:8080/api

# LINE User ID of the default admin account used in the login screen pre-fill.
# Must have role=admin or role=staff in Firestore for the login to succeed.
VITE_DEFAULT_ADMIN_UID=REPLACE_WITH_YOUR_LINE_UID
