# Dependencies
node_modules/
*/node_modules/
package-lock.json
yarn.lock

# Environment variables — ignore real values, keep *.example committed
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# frontend (real values gitignored; .env.*.example are committed templates)
frontend/.env
frontend/.env.development
frontend/.env.production
# backend (real values gitignored; .env.*.example are committed templates)
backend/.env
backend/.env.development
backend/.env.production
# dashboard (desktop admin web)
dashboard/.env
dashboard/.env.development
dashboard/.env.production
.cursor/
# but never ignore the committed templates
!**/*.example

# Backend secrets (Firebase service account, never commit)
backend/serviceAccount.json
**/serviceAccount*.json
**/*firebase-adminsdk*.json
**/*-adminsdk-*.json

# Build outputs
frontend/dist/
frontend/build/
backend/build/
server/build/
build/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

