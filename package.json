{
  "name": "yoga-booking-liff",
  "version": "1.0.0",
  "description": "LINE LIFF Yoga Class Booking System",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "dashboard"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "dev:api": "npm run dev --workspace backend",
    "dev:dashboard": "npm run dev --workspace dashboard",
    "dev:full": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev\"",
    "build:dashboard": "npm run build --workspace dashboard",
    "start:api": "npm run start:prod --workspace backend",
    "build": "npm run build --workspace frontend",
    "build:dev": "npm run build --workspace frontend -- --mode development",
    "deploy:dev": "npm run build:dev && firebase deploy --only hosting,firestore --project dev",
    "deploy:dev:hosting": "npm run build:dev && firebase deploy --only hosting --project dev",
    "deploy:dev:rules": "firebase deploy --only firestore:rules --project dev",
    "deploy:prod": "npm run build && firebase deploy --only hosting,firestore --project prod",
    "deploy:prod:rules": "firebase deploy --only firestore:rules --project prod",
    "deploy": "npm run deploy:prod",
    "create-classes": "node scripts/create-monday-classes.js",
    "create-classes:4weeks": "node scripts/create-monday-classes.js --weeks 4",
    "create-classes:dry-run": "node scripts/create-monday-classes.js --dry-run",
    "create-weekly": "node scripts/create-weekly-classes.js",
    "create-weekly:4weeks": "node scripts/create-weekly-classes.js --weeks 4",
    "create-weekly:dry-run": "node scripts/create-weekly-classes.js --dry-run"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "marked": "^18.0.5",
    "playwright": "^1.60.0",
    "vite": "^7.3.1"
  }
}
