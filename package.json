{
  "name": "yoga-booking-liff",
  "version": "1.0.0",
  "description": "LINE LIFF Yoga Class Booking System",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "cd client && npm run dev",
    "emulators": "firebase emulators:start --only auth,functions,firestore",
    "dev:full": "concurrently -k -n EMU,VITE -c blue,green \"npm run emulators\" \"npm run dev\"",
    "build": "cd client && npm run build",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy": "npm run build && firebase deploy --only hosting",
    "create-classes": "node scripts/create-monday-classes.js",
    "create-classes:4weeks": "node scripts/create-monday-classes.js --weeks 4",
    "create-classes:dry-run": "node scripts/create-monday-classes.js --dry-run",
    "create-weekly": "node scripts/create-weekly-classes.js",
    "create-weekly:4weeks": "node scripts/create-weekly-classes.js --weeks 4",
    "create-weekly:dry-run": "node scripts/create-weekly-classes.js --dry-run"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "marked": "^18.0.5",
    "playwright": "^1.60.0",
    "vite": "^7.3.1"
  }
}
