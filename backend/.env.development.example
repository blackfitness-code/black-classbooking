# Backend DEV env example — โหลดเมื่อ NODE_ENV=development (`npm run dev` / cross-env NODE_ENV=development).
# Copy to .env.development and fill in real values. This file IS committed; never put real secrets here.

# Port the Express server listens on
PORT=8080

# Allowed CORS origins (comma-separated). Include Vite dev server and any dev Hosting URL.
CORS_ORIGIN=http://localhost:3000,https://CHANGEME-dev-hosting.web.app,https://CHANGEME-dev-hosting.firebaseapp.com

# Session JWT — use a randomly generated string for dev (e.g. `openssl rand -hex 32`)
JWT_SECRET=CHANGEME_DEV_JWT_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# LINE channel ID for dev LIFF (leave empty to use dev-bypass devUid)
LINE_CHANNEL_ID=

# Firebase dev project ID
FIREBASE_PROJECT_ID=CHANGEME-dev-project-id
