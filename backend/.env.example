# ============================================================
# .env.example — copy to .env and fill in your values
# ============================================================
# NOTE: backend/serviceAccount.json is gitignored.
#       Add it locally for Firebase credential (option C).
# ============================================================

# --- App ---
NODE_ENV=development
PORT=8080

# CORS origin: comma-separated list or * for all
# In production set this to your frontend URL, e.g. https://your-app.web.app
CORS_ORIGIN=*

# --- JWT ---
# REQUIRED in production. Use a long random secret (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-use-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- LINE (Phase 1) ---
LINE_CHANNEL_ID=

# --- Firebase ---
# Option A: paste the entire serviceAccount.json contents as a single JSON string
FIREBASE_SERVICE_ACCOUNT=

# Option B: path to the ADC key file (e.g. GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json)
GOOGLE_APPLICATION_CREDENTIALS=

# Optionally pin the Firebase project
FIREBASE_PROJECT_ID=

# NOTE: Option C — place backend/serviceAccount.json locally (auto-detected, gitignored)
