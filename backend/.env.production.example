# Backend PRODUCTION env example — โหลดเมื่อ NODE_ENV=production (`npm run start:prod` / cross-env NODE_ENV=production).
# Copy to .env.production and fill in real values. This file IS committed; never put real secrets here.
# On Cloud Run / GCE you can set these as env vars directly instead of using this file.

# Port the Express server listens on
PORT=8080

# Allowed CORS origins for production frontend (comma-separated)
CORS_ORIGIN=https://CHANGEME-prod-frontend.web.app

# Session JWT — REQUIRED in production: generate with `openssl rand -hex 64`
JWT_SECRET=CHANGEME_GENERATE_A_LONG_RANDOM_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# LINE channel ID for prod LIFF
LINE_CHANNEL_ID=CHANGEME_PROD_LINE_CHANNEL_ID

# Firebase prod project ID
FIREBASE_PROJECT_ID=CHANGEME-prod-project-id
# Optional: JSON string of service account key (for non-GCP hosting). Leave empty on Cloud Run (uses ADC).
FIREBASE_SERVICE_ACCOUNT=
