# Frontend PRODUCTION env example — โหลดโดย `npm run build` (Vite mode=production).
# Copy to .env.production and fill in real values. This file IS committed; never put real secrets here.

# Backend API base URL for production (full URL of deployed backend + /api)
VITE_API_BASE_URL=https://CHANGEME-prod-backend/api

# LIFF ID for prod channel — find in LINE Developers Console
VITE_LIFF_ID=CHANGEME_PROD_LIFF_ID

# Firebase web config for prod project — get from Firebase Console → Project settings → Web app → SDK config
# These values are public (bundled into the JS), not secrets.
VITE_FIREBASE_API_KEY=CHANGEME_PROD_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=CHANGEME-prod-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=CHANGEME-prod-project-id
VITE_FIREBASE_STORAGE_BUCKET=CHANGEME-prod-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=CHANGEME_PROD_SENDER_ID
VITE_FIREBASE_APP_ID=CHANGEME_PROD_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=CHANGEME_PROD_MEASUREMENT_ID
