# Frontend DEV env example — โหลดโดย `npm run dev` (Vite mode=development).
# Copy to .env.development and fill in real values. This file IS committed; never put real secrets here.
# For mobile LINE testing via deployed dev Hosting, change VITE_API_BASE_URL to your tunnel URL.

# Backend API base URL (local dev server, or tunnel URL for mobile testing)
VITE_API_BASE_URL=http://localhost:8080/api

# LIFF ID for dev channel — find in LINE Developers Console
VITE_LIFF_ID=CHANGEME_DEV_LIFF_ID

# Firebase web config for dev project — get from Firebase Console → Project settings → Web app → SDK config
VITE_FIREBASE_API_KEY=CHANGEME_DEV_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=CHANGEME-dev-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=CHANGEME-dev-project-id
VITE_FIREBASE_STORAGE_BUCKET=CHANGEME-dev-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=CHANGEME_DEV_SENDER_ID
VITE_FIREBASE_APP_ID=CHANGEME_DEV_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=
